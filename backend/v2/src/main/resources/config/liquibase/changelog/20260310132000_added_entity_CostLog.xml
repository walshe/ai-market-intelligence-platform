<?xml version="1.0" encoding="utf-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="20260310132000-1" author="junie">
        <createTable tableName="cost_log">
            <column name="id" type="bigint">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="call_type" type="varchar(255)">
                <constraints nullable="false" />
            </column>
            <column name="model_name" type="varchar(255)">
                <constraints nullable="false" />
            </column>
            <column name="input_tokens" type="integer">
                <constraints nullable="false" />
            </column>
            <column name="output_tokens" type="integer" />
            <column name="total_tokens" type="integer">
                <constraints nullable="false" />
            </column>
            <column name="estimated_usd_cost" type="decimal(21,10)">
                <constraints nullable="false" />
            </column>
            <column name="document_id" type="bigint" />
            <column name="correlation_id" type="varchar(255)" />
            <column name="created_at" type="${datetimeType}" defaultValueComputed="now()">
                <constraints nullable="false" />
            </column>
        </createTable>

        <createIndex indexName="idx_cost_log_model_name" tableName="cost_log">
            <column name="model_name"/>
        </createIndex>
        <createIndex indexName="idx_cost_log_call_type" tableName="cost_log">
            <column name="call_type"/>
        </createIndex>
        <createIndex indexName="idx_cost_log_created_at" tableName="cost_log">
            <column name="created_at"/>
        </createIndex>
    </changeSet>
</databaseChangeLog>
